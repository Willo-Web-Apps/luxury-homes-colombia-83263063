---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Your New Business", description = "I want to create a boutique real estate business in Medellin and other major cities in Colombia for renting homes and selling homes. Focused on luxury for both locals and foreigners houses apartments villas buildings" } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Your New Business",
      "description": "I want to create a boutique real estate business in Medellin and other major cities in Colombia for renting homes and selling homes. Focused on luxury for both locals and foreigners houses apartments villas buildings",
      "url": "https://luxury-homes-colombia.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
