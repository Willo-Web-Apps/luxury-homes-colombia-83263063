---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Altura Living — Luxury Real Estate in Medellin & Colombia",
  description = "Boutique luxury real estate in Medellín, Bogotá, and Cartagena. Handpicked villas, penthouses, and apartments for discerning buyers and renters. Fully bilingual concierge service."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#1B4D3E" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "RealEstateAgent",
      "name": "Altura Living",
      "description": "Boutique luxury real estate in Medellín, Bogotá, and Cartagena. Handpicked villas, penthouses, and apartments for discerning buyers and renters.",
      "url": "https://luxury-homes-colombia.onrender.com",
      "areaServed": ["Medellín", "Bogotá", "Cartagena"],
      "serviceType": "Luxury Real Estate Sales and Rentals",
      "availableLanguage": ["English", "Spanish"]
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
