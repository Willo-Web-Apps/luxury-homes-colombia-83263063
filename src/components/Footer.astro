---
const year = new Date().getFullYear();
---
<footer style="background: oklch(0.14 0.010 80); border-top: 1px solid oklch(0.25 0.012 80);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

    <div class="grid md:grid-cols-3 gap-10 mb-12">

      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-md flex items-center justify-center text-white text-xs font-bold font-display" style="background: oklch(0.43 0.13 162);">A</div>
          <span class="text-base font-bold tracking-tight text-white font-display">
            Altura <span class="font-light">Living</span>
          </span>
        </div>
        <p class="text-sm text-white/40 leading-relaxed font-body max-w-xs">
          Boutique luxury real estate in Medellín, Bogotá, and Cartagena. Curating Colombia's finest addresses since 2019.
        </p>
        <p class="mt-4 text-xs text-white/25 font-body italic">
          "Where Colombia's Finest Addresses Find You"
        </p>
      </div>

      <!-- Markets column -->
      <div>
        <h4 class="text-xs font-semibold tracking-[0.15em] uppercase mb-5 font-body" style="color: oklch(0.73 0.14 78);">Our Markets</h4>
        <ul class="space-y-3 text-sm text-white/50 font-body">
          <li><a href="#listings" class="hover:text-white transition-colors">Medellín — El Poblado, Laureles</a></li>
          <li><a href="#listings" class="hover:text-white transition-colors">Bogotá — Rosales, La Cabrera</a></li>
          <li><a href="#listings" class="hover:text-white transition-colors">Cartagena — Ciudad Amurallada, Bocagrande</a></li>
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h4 class="text-xs font-semibold tracking-[0.15em] uppercase mb-5 font-body" style="color: oklch(0.73 0.14 78);">Contact</h4>
        <ul class="space-y-3 text-sm text-white/50 font-body">
          <li>
            <a href="mailto:hello@alturalivng.co" class="hover:text-white transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              hello@alturalivng.co
            </a>
          </li>
          <li>
            <a href="https://wa.me/573001234567" class="hover:text-white transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp (English / Español)
            </a>
          </li>
          <li class="text-white/30">Medellín · Bogotá · Cartagena, Colombia</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t flex flex-col md:flex-row items-center justify-between gap-3" style="border-color: oklch(0.25 0.012 80);">
      <p class="text-xs text-white/25 font-body">&copy; {year} Altura Living. All rights reserved.</p>
      <p class="text-xs text-white/20 font-body">Luxury Real Estate · Colombia · Bilingual Service</p>
    </div>

  </div>
</footer>
